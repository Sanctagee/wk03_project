  "definitions": {
    "Student": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "example": "Tony"
        },
        "lastName": {
          "type": "string",
          "example": "Gabito"
        },
        "regNumber": {
          "type": "string",
          "example": "STU-001"
        },
        "grade": {
          "type": "string",
          "example": "JSS1"
        },
        "gender": {
          "type": "string",
          "example": "Male"
        },
        "dateOfBirth": {
          "type": "string",
          "example": "2010-05-14"
        },
        "email": {
          "type": "string",
          "example": "tony.gabito@gabbytech.com"
        },
        "stateOfOrigin": {
          "type": "string",
          "example": "Lagos"
        },
        "status": {
          "type": "string",
          "example": "Active"
        }
      }
    },
    "Course": {
      "type": "object",
      "properties": {
        "courseCode": {
          "type": "string",
          "example": "MTH101"
        },
        "courseName": {
          "type": "string",
          "example": "Mathematics"
        },
        "department": {
          "type": "string",
          "example": "Sciences"
        },
        "gradeLevel": {
          "type": "string",
          "example": "JSS1"
        },
        "teacherName": {
          "type": "string",
          "example": "Mr. Adeyemi"
        },
        "description": {
          "type": "string",
          "example": "Basic mathematics for junior secondary students"
        },
        "daysPerWeek": {
          "type": "number",
          "example": 3
        },
        "isActive": {
          "type": "boolean",
          "example": true
        }
      }
    }
  }
